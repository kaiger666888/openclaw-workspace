    {"type": "bulleted_list_item", "bulleted_list_item": {"rich_text": [{"type": "text", "text": {"content": "定性优于定量：先判断商业模式，再看财务数据"}}]}},
    {"type": "bulleted_list_item", "bulleted_list_item": {"rich_text": [{"type": "text", "text": {"content": "护城河思维：好公司拥有持久的竞争优势"}}]}},

